{
    "name": "Modern",
    "description": "Clean, modern e-commerce theme with professional design",
    "version": "1.0.0",
    "author": "TradeCMS Team",
    "author_url": "https://tradecms.com",
    "screenshot": "screenshot.png",
    "tags": ["modern", "clean", "professional", "responsive"],
    "requires_tradecms": "1.0.0",
    "license": "GPL-2.0+",
    "license_url": "https://www.gnu.org/licenses/gpl-2.0.html",
    "support": {
        "docs": "https://docs.tradecms.com/themes/modern",
        "forum": "https://community.tradecms.com/themes/modern",
        "issues": "https://github.com/tradecms/theme-modern/issues"
    },
    "features": [
        "responsive-design",
        "custom-colors", 
        "custom-fonts",
        "product-gallery",
        "shopping-cart",
        "user-accounts",
        "search-functionality"
    ],
    "customizer": {
        "colors": {
            "primary": "#2563eb",
            "secondary": "#64748b",
            "accent": "#10b981",
            "background": "#f8fafc",
            "text": "#2c3e50"
        },
        "typography": {
            "font_family": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto",
            "font_size_base": "16px",
            "line_height": "1.6"
        },
        "layout": {
            "container_width": "1200px",
            "sidebar_width": "250px",
            "grid_columns": 4
        }
    },
    "template_hierarchy": {
        "home": "home.html",
        "product_list": "product_list.html", 
        "product_detail": "product_detail.html",
        "cart": "cart.html",
        "checkout": "checkout.html",
        "user_profile": "accounts/profile.html",
        "login": "registration/login.html"
    }
}